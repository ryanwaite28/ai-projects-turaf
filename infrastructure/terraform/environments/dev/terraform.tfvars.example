# Turaf Development Environment - Cost-Optimized Demo Configuration
# Copy this file to terraform.tfvars and update values as needed

# Environment
environment = "dev"
aws_region  = "us-east-1"

# VPC Configuration
vpc_cidr = "10.0.0.0/16"
availability_zones = [
  "us-east-1a",
  "us-east-1b"
]

# Networking - Cost Optimized
enable_nat_gateway = false  # Save ~$65/month - use VPC endpoints instead
single_nat_gateway = false  # Not used when NAT gateway disabled
enable_flow_logs   = false  # Save ~$5/month

# Database - Free Tier Configuration
db_instance_class             = "db.t3.micro"      # Free Tier eligible
db_allocated_storage          = 20                 # Free Tier: 20 GB
db_max_allocated_storage      = 50
backup_retention_days         = 1                  # Minimum retention
enable_multi_az               = false              # Single-AZ for demo
deletion_protection           = false              # Allow easy cleanup
enable_performance_insights   = false              # Save ~$7/month

# Redis - Disabled for Cost Savings
enable_redis                  = false              # Save ~$12/month
redis_node_type               = "cache.t3.micro"   # Only used if enabled
redis_num_cache_nodes         = 1
redis_snapshot_retention_days = 1

# DocumentDB - Disabled for Cost Savings
enable_documentdb             = false              # Save ~$54/month
documentdb_instance_class     = "db.t3.medium"     # Only used if enabled
documentdb_instance_count     = 1
documentdb_backup_retention_days = 1

# Storage
enable_s3_versioning        = false
enable_separate_s3_buckets  = false
s3_log_retention_days       = 7
s3_backup_retention_days    = 7

# Messaging
enable_event_archive        = false
enable_chat_queue           = false
enable_notification_queue   = false
enable_report_queue         = false
enable_sns_topics           = false
enable_queue_alarms         = false
event_archive_retention_days = 7
message_retention_seconds    = 345600

# Compute - Shared Infrastructure Only (services managed via CI/CD)
acm_certificate_arn           = ""  # Optional for dev
use_fargate_spot              = true
enable_container_insights     = false

# Lambda
lambda_artifacts_bucket       = ""
log_retention_days            = 7
from_email                    = ""
enable_event_processor        = false
enable_notification_processor = false
enable_report_generator       = false
lambda_use_vpc_mode           = false
lambda_runtime                = "nodejs20.x"

# Monitoring - All disabled for cost savings
enable_alarms       = false
enable_dashboard    = false
enable_sns_alerts   = false
enable_xray         = false
enable_log_insights = false
alarm_email         = ""
cpu_threshold       = 80
memory_threshold    = 80
response_time_threshold = 2

# Tags
tags = {
  Project     = "turaf"
  Environment = "dev"
  ManagedBy   = "terraform"
}
